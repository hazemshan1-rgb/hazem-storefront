# ConvertKit — get form IDs from kit.com → Forms → your form → Embed → Script tag
# Each guide has its own form so you can tag subscribers by interest
VITE_CONVERTKIT_FORM_BIOFLOC=your_biofloc_form_id
VITE_CONVERTKIT_FORM_STRATEGIES=your_strategies_form_id

# Calendly — your event URL from Calendly dashboard (Share → Copy Link)
# Format: https://calendly.com/your-username/consultation
VITE_CALENDLY_URL=https://calendly.com/your-username/consultation

# Lemon Squeezy — consultation session checkout URLs
# Create products in LS, set redirect URL to https://your-domain.com/book-consultation
# Format: https://your-store.lemonsqueezy.com/checkout/buy/PRODUCT_UUID
VITE_CONSULTATION_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/PRODUCT_UUID
VITE_CONSULTATION_30_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/PRODUCT_UUID

# AI Providers — used by AquaAssist AI and diagnostic tools (api/chat.ts, etc.)
# Add these as SERVER-SIDE environment variables in Vercel (not prefixed with VITE_)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here
