# ConvertKit — get from your form embed code at kit.com
VITE_CONVERTKIT_FORM_ID=your_form_id_here

# Calendly — your event URL from Calendly dashboard (Share → Copy Link)
# Format: https://calendly.com/your-username/consultation
VITE_CALENDLY_URL=https://calendly.com/your-username/consultation

# Lemon Squeezy — consultation session checkout URL
# Create a $500 product in LS, set redirect URL to https://your-domain.com/book-consultation
# Format: https://your-store.lemonsqueezy.com/checkout/buy/PRODUCT_UUID
VITE_CONSULTATION_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/PRODUCT_UUID
